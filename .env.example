# ViaAccess Cloud
VIAACCESS_API_URL="https://api.viaaccess.com.br"
VIAACCESS_API_KEY="vac_…"

# Frigate MQTT (same network as Frigate)
FRIGATE_MQTT_URL="mqtt://mqtt:1883"
FRIGATE_MQTT_TOPIC_PREFIX="frigate"

# Frigate HTTP API (snapshots)
FRIGATE_BASE_URL="http://frigate:5000"

# Camera + zone → Access Point slug (ViaAccess tenant)
FRIGATE_ACCESS_POINT_MAP='[{"accessPoint":"entrada-principal","camera":"portao-principal","zone":"entrada","labels":["person"]}]'

# Retry outbox when cloud is unreachable
OUTBOX_PATH="/data/outbox.jsonl"
OUTBOX_FLUSH_INTERVAL_MS="30000"
