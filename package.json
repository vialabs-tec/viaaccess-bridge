{
  "name": "@vialabs/viaaccess-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Frigate MQTT → VADP bridge for ViaAccess Cloud",
  "type": "module",
  "bin": {
    "viaaccess-bridge": "./dist/main.js"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/main.js",
    "test": "vitest run",
    "docker:build": "docker build -t ghcr.io/vialabs-tec/viaaccess-bridge:local ."
  },
  "dependencies": {
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}
