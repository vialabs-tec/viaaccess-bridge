# Optional overrides (systemd EnvironmentFile)
# IDENTITY_URL="https://identity.cliente.com"
# IDENTITY_DEVICE_KEY="idb_…"
# EMIT_DETECTION="true"
# RELAY_ENABLED="true"
# RELAY_GPIO_PIN="17"
# KY-016 RGB status LED (onboard 1kΩ resistors; common cathode → GND)
# STATUS_LED_ENABLED="true"
# STATUS_LED_RED_PIN="22"
# STATUS_LED_GREEN_PIN="27"
# STATUS_LED_BLUE_PIN="23"
# SETUP_PIN="1234"
# STDIN_SCANNER="true"
# USB keyboard-wedge via Linux evdev (preferred under systemd):
# HID_SCANNER_AUTO="true"
# Or pin a device: HID_SCANNER_DEVICE="/dev/input/by-id/usb-…-event-kbd"
# CONTINGENCY_ENABLED="true"
# ONLINE_REDEEM_TIMEOUT_MS="3000"
# MAX_POLICY_STALE_HOURS="168"
# VIAACCESS_QR_POLICY="/etc/viaaccess-qr-reader/policy-snapshot.json"
# VIAACCESS_QR_OUTBOX="/etc/viaaccess-qr-reader/outbox.json"
