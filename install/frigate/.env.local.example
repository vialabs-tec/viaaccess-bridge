# Mercadinho — desenvolvimento local (Mac/Linux com Docker)
# cp .env.local.example .env
#
# Pré-requisitos no host:
#   - ViaAccess API em http://localhost:3002 (npm run dev em ../viaaccess)
#   - Pontos entrada-principal e interior-principal criados no dashboard
#   - API key vac_… com escopo nos dois slugs
#
# No Linux, o compose já adiciona host.docker.internal via extra_hosts.

# API local (container → host)
VIAACCESS_API_URL="http://host.docker.internal:3002"
VIAACCESS_API_KEY="vac_COLE_SUA_CHAVE_AQUI"

# Imagem local (padrão no compose). GHCR exige login — use build local em dev.
VIAACCESS_BRIDGE_IMAGE="viaaccess-bridge:local"

FRIGATE_ACCESS_POINT_MAP='[
  {
    "accessPoint": "entrada-principal",
    "camera": "portao-principal",
    "zone": "entrada",
    "labels": ["person"]
  },
  {
    "accessPoint": "interior-principal",
    "camera": "portao-principal",
    "zone": "interior",
    "labels": ["person"],
    "presenceSessionGapSeconds": 20
  }
]'

# Opcional — debug MQTT no host (porta 1883 publicada no compose)
# FRIGATE_MQTT_TOPIC_PREFIX="frigate"
