# ViaAccess Cloud (obtenha a API key no painel do tenant)
VIAACCESS_API_URL="https://api.viaaccess.com.br"
VIAACCESS_API_KEY="vac_…"

# Mapa câmera Frigate + zona → slug do ponto de acesso no ViaAccess
# accessPoint deve existir no tenant (ex.: entrada-principal)
FRIGATE_ACCESS_POINT_MAP='[{"accessPoint":"entrada-principal","camera":"portao-principal","zone":"entrada","labels":["person"]}]'

# Opcional
# FRIGATE_MQTT_TOPIC_PREFIX="frigate"
# OUTBOX_FLUSH_INTERVAL_MS="30000"
