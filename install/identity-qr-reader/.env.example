# ViaAccess Identity (Phase 1b dynamic QR)
IDENTITY_URL="http://localhost:3100"

# Device key from Admin → Access point → Leitores (idb_…)
IDENTITY_DEVICE_KEY="idb_…"

# Emit detection after validation (recommended for standalone USB reader without camera)
EMIT_DETECTION="true"

# Ignore identical scans within this window (ms)
DEBOUNCE_MS="2000"

# --- Modo HTTP (catraca / controlador com webhook) — npm run start:http ---
# HTTP_HOST="0.0.0.0"
# HTTP_PORT="3710"
# WEBHOOK_SECRET=""          # opcional; exija X-Webhook-Secret no POST /scan
# UNLOCK_WEBHOOK_URL=""      # ex.: http://192.168.1.50/api/unlock (controlador da catraca)
# UNLOCK_ON_AUTHORIZED_ONLY="true"
